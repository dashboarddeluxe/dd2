{
  "name": "dashboard-deluxe-2",
  "description": "Dashboard Deluxe 2 - Hugo + Tailwind link dashboard",
  "version": "4.0.0",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/check-env.js",
    "prebuild": "node scripts/check-env.js",
    "dev": "node scripts/run-hugo.js server --cleanDestinationDir",
    "build": "node scripts/run-hugo.js --gc --minify --cleanDestinationDir",
    "test": "node scripts/run-python.js scripts/validate-link-groups.py",
    "validate-link-groups": "node scripts/run-python.js scripts/validate-link-groups.py"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@netlify/plugin-lighthouse": "^6.0.4",
    "@tailwindcss/cli": "^4.1.0",
    "hugo-extended": "^0.163.3",
    "tailwindcss": "^4.1.0"
  }
}
